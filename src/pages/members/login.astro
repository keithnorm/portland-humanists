---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getUserFromRequest } from '../../lib/identity';

const user = await getUserFromRequest(Astro.request, Astro.url.origin);
const redirectTo = Astro.url.searchParams.get('redirect') || '/members';
if (user) return Astro.redirect(redirectTo);
---

<BaseLayout title="Member Login - Humanists of Greater Portland">
  <section class="hgp-cta text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Members Area</h1>
      <p class="text-xl text-[var(--hgp-on-primary)]">Log in to see the membership list, sign-up sheets, and members-only videos.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-md mx-auto px-4">
      <form id="login-form" data-redirect={redirectTo}>
        <label class="block text-sm font-medium text-neutral-700 mb-1" for="login">Username or email</label>
        <input id="login" name="login" autocomplete="username" required
          class="w-full border border-neutral-300 rounded-lg px-3 py-2.5 mb-4" />
        <label class="block text-sm font-medium text-neutral-700 mb-1" for="password">Password</label>
        <input id="password" name="password" type="password" autocomplete="current-password" required
          class="w-full border border-neutral-300 rounded-lg px-3 py-2.5 mb-2" />
        <p class="text-sm text-neutral-500 mb-4">
          Same username (or email) and password you used on the old members site.
        </p>
        <button type="submit" id="login-submit"
          class="w-full bg-[var(--hgp-primary)] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[var(--hgp-mid)] transition-colors">
          Log in
        </button>
        <p id="login-error" class="hidden text-sm text-red-600 mt-3"></p>
      </form>

      <div class="border-t border-neutral-200 mt-8 pt-6 text-center">
        <button id="recovery-btn" class="text-[var(--hgp-primary)] hover:underline text-sm">
          Forgot your password? / Have an invite?
        </button>
        <p class="text-sm text-neutral-500 mt-3">
          Need help? Contact <a href="mailto:info@portlandhumanists.org" class="text-[var(--hgp-primary)] hover:underline">info@portlandhumanists.org</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import netlifyIdentity from 'netlify-identity-widget';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorEl = document.getElementById('login-error')!;
  const submitBtn = document.getElementById('login-submit') as HTMLButtonElement;
  const redirectTo = form?.dataset.redirect || '/members';

  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
    submitBtn.disabled = false;
    submitBtn.textContent = 'Log in';
  }

  async function establishSession(token: string, refreshToken?: string) {
    const res = await fetch('/api/members/session', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token, refresh_token: refreshToken }),
    });
    if (res.ok) window.location.href = redirectTo;
    else showError('Login succeeded but the session could not be created — please try again.');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Logging in…';

    const body = JSON.stringify({
      login: (document.getElementById('login') as HTMLInputElement).value,
      password: (document.getElementById('password') as HTMLInputElement).value,
    });
    const headers = { 'Content-Type': 'application/json' };

    try {
      if (import.meta.env.DEV) {
        // Dev twin validates old-site credentials and sets the cookie itself.
        const res = await fetch('/api/members/login', { method: 'POST', headers, body });
        if (res.ok) window.location.href = redirectTo;
        else showError((await res.json()).error ?? 'Invalid login or password');
      } else {
        // Production: bridge function returns Identity tokens.
        const res = await fetch('/.netlify/functions/auth-bridge', { method: 'POST', headers, body });
        if (res.ok) {
          const tokens = await res.json();
          await establishSession(tokens.access_token, tokens.refresh_token);
        } else {
          showError((await res.json().catch(() => ({}))).error ?? 'Invalid login or password');
        }
      }
    } catch {
      showError('Something went wrong — please try again.');
    }
  });

  // Identity widget handles recovery emails, invites, and email confirmations
  // (their token fragments land on this page via the BaseLayout redirect).
  const apiUrl = import.meta.env.PUBLIC_IDENTITY_API_URL as string | undefined;
  netlifyIdentity.init(apiUrl ? { APIUrl: apiUrl } : undefined);
  netlifyIdentity.on('login', async (user) => {
    netlifyIdentity.close();
    await establishSession(await user.jwt(), (user as any).token?.refresh_token);
  });
  document.getElementById('recovery-btn')?.addEventListener('click', () => netlifyIdentity.open());
</script>
