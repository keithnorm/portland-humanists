---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import { getSignups } from '../../lib/membersStore';
import { parseInTimezone } from '../../utils/time';

const member = Astro.locals.member!;
const message = Astro.url.searchParams.get('msg');

const timezone = 'America/Los_Angeles';
const now = new Date();
const allEvents = await getCollection('events');
const upcoming = allEvents
  .filter(e => parseInTimezone(e.data.endTime, timezone) > now)
  .sort((a, b) => parseInTimezone(a.data.startTime, timezone).getTime() - parseInTimezone(b.data.startTime, timezone).getTime());

const signups = await getSignups();
const signupBySlug = new Map(signups.map(s => [s.eventSlug, s]));

function formatDate(v: Date | string): string {
  const d = v instanceof Date ? v : new Date(v);
  return new Intl.DateTimeFormat('en-US', { weekday: 'long', month: 'long', day: 'numeric', timeZone: timezone }).format(d);
}
---

<BaseLayout title="Sign-up Sheets - Humanists of Greater Portland">
  <section class="hgp-cta text-white py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/members" class="inline-flex items-center gap-2 text-[var(--hgp-on-primary)] hover:text-white mb-4 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Members Area
      </a>
      <h1 class="text-4xl font-bold mb-2">Sign-up Sheets: Readings</h1>
      <p class="text-[var(--hgp-on-primary)]">Volunteer to give the reading at an upcoming Sunday program.</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {message && (
        <div class="mb-8 bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3">{message}</div>
      )}

      {upcoming.length === 0 ? (
        <p class="text-neutral-600">No upcoming programs are scheduled yet — check back soon.</p>
      ) : (
        <div class="space-y-4">
          {upcoming.map(event => {
            const signup = signupBySlug.get(event.slug);
            const isMine = signup?.email === member.email;
            return (
              <div class="flex flex-col sm:flex-row sm:items-center gap-4 bg-neutral-50 rounded-xl p-6">
                <div class="flex-1">
                  <div class="text-sm font-semibold text-[var(--hgp-accent)] uppercase tracking-wide mb-1">
                    {formatDate(event.data.startTime)}
                  </div>
                  <a href={`/events/${event.slug}`} class="text-lg font-bold text-neutral-900 hover:text-[var(--hgp-primary)]">
                    {event.data.title}
                  </a>
                  <div class="text-sm text-neutral-600 mt-1">
                    {signup ? (
                      <span>
                        Reading: <strong>{signup.name}</strong>{isMine && ' (you)'}
                      </span>
                    ) : (
                      <span class="text-green-700 font-medium">Reading slot open</span>
                    )}
                  </div>
                </div>
                <div>
                  {!signup && (
                    <form method="POST" action="/api/members/readings">
                      <input type="hidden" name="action" value="signup" />
                      <input type="hidden" name="slug" value={event.slug} />
                      <button type="submit" class="bg-[var(--hgp-primary)] text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-[var(--hgp-mid)] transition-colors">
                        Sign up to read
                      </button>
                    </form>
                  )}
                  {isMine && (
                    <form method="POST" action="/api/members/readings">
                      <input type="hidden" name="action" value="cancel" />
                      <input type="hidden" name="slug" value={event.slug} />
                      <button type="submit" class="border-2 border-neutral-300 text-neutral-600 px-5 py-2.5 rounded-lg font-semibold hover:border-red-300 hover:text-red-600 transition-colors">
                        Cancel my signup
                      </button>
                    </form>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      )}

      <p class="text-sm text-neutral-500 mt-10">
        One reader per program. Signing up as {member.name} ({member.email}).
      </p>
    </div>
  </section>
</BaseLayout>
