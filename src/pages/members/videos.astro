---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import PastEventsGrid, { type PastEventItem } from '../../components/PastEventsGrid';
import { getVideos } from '../../lib/membersStore';

// Archive videos from the old members site (Netlify Blobs — private data).
const archive = await getVideos();

// Recordings already published on the public site (Tina events collection).
const events = await getCollection('events');
const publicRecordings = events.filter(e => e.data.youtubeId || e.data.vimeoId);

// Merge, preferring the public event entry (it links to a detail page).
// Dedupe by video id and by title+date — the same program often has a
// public YouTube recording and a members-only Vimeo copy.
const seen = new Set<string>();
const items: PastEventItem[] = [];
const titleDay = (title: string, d: Date | string) =>
  `${title.toLowerCase().replace(/\(private\)/g, '').replace(/[^a-z0-9]+/g, ' ').trim()}|${String(
    d instanceof Date ? d.toISOString() : d
  ).slice(0, 10)}`;

for (const e of publicRecordings) {
  for (const id of [e.data.youtubeId, e.data.vimeoId]) if (id) seen.add(id);
  seen.add(titleDay(e.data.title, e.data.startTime));
  items.push({
    slug: e.slug,
    title: e.data.title,
    startTime: e.data.startTime,
    presenter: e.data.presenter,
    description: e.data.description,
    youtubeId: e.data.youtubeId,
    vimeoId: e.data.vimeoId,
    vimeoThumbnail: (e.data as any).vimeoThumbnail,
    embed: Boolean(e.data.vimeoId && !e.data.youtubeId),
  });
}

for (const v of archive) {
  const id = v.vimeoId ?? v.youtubeId;
  const day = titleDay(v.title, `${v.date ?? v.uploadDate}`);
  if (!id || seen.has(id) || seen.has(day)) continue;
  seen.add(id);
  seen.add(day);
  items.push({
    title: v.title,
    startTime: `${v.date ?? v.uploadDate}T12:00:00`,
    presenter: v.presenter,
    description: v.description?.slice(0, 200),
    youtubeId: v.youtubeId,
    vimeoId: v.vimeoId,
    vimeoHash: v.vimeoHash,
    badge: v.vimeoId ? 'Members only' : undefined,
    embed: true,
  });
}

// startTime is a Date for collection events but an ISO string for archive
// items — compare as timestamps, not strings.
const ts = (x: Date | string) => (x instanceof Date ? x : new Date(String(x).replace(' ', 'T'))).getTime();
items.sort((a, b) => ts(b.startTime) - ts(a.startTime));
---

<BaseLayout title="Video Library - Humanists of Greater Portland">
  <section class="hgp-cta text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/members" class="inline-flex items-center gap-2 text-[var(--hgp-on-primary)] hover:text-white mb-4 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Members Area
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Video Library</h1>
      <p class="text-xl text-[var(--hgp-on-primary)] max-w-2xl">
        {items.length} recordings — every past program, including members-only videos.
        Please don't share members-only recordings outside HGP.
      </p>
    </div>
  </section>

  <section class="py-8 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <PastEventsGrid events={items} client:load />
    </div>
  </section>
</BaseLayout>
