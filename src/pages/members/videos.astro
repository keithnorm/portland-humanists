---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getVideos } from '../../lib/membersStore';

const videos = (await getVideos()).slice()
  .sort((a, b) => (b.date ?? b.uploadDate ?? '').localeCompare(a.date ?? a.uploadDate ?? ''));

function formatDate(iso?: string): string {
  if (!iso) return '';
  const d = new Date(`${iso}T12:00:00`);
  return isNaN(d.getTime()) ? iso : new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);
}

function embedSrc(v: (typeof videos)[number]): string {
  if (v.vimeoId) return `https://player.vimeo.com/video/${v.vimeoId}${v.vimeoHash ? `?h=${v.vimeoHash}` : ''}`;
  return `https://www.youtube.com/embed/${v.youtubeId}`;
}
---

<BaseLayout title="Members-Only Videos - Humanists of Greater Portland">
  <section class="hgp-cta text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/members" class="inline-flex items-center gap-2 text-[var(--hgp-on-primary)] hover:text-white mb-4 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Members Area
      </a>
      <h1 class="text-4xl font-bold mb-2">Video Library</h1>
      <p class="text-[var(--hgp-on-primary)]">{videos.length} recordings of past programs. Please don't share these outside HGP.</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row gap-3 mb-8">
        <input id="video-search" type="search" placeholder="Search videos…"
          class="flex-1 border border-neutral-300 rounded-lg px-4 py-2.5" />
        <select id="video-field" class="border border-neutral-300 rounded-lg px-3 py-2.5">
          <option value="">Everything</option>
          <option value="title">Title</option>
          <option value="presenter">Presenter</option>
          <option value="description">Description</option>
        </select>
        <select id="video-sort" class="border border-neutral-300 rounded-lg px-3 py-2.5">
          <option value="date-desc">Recorded — newest first</option>
          <option value="date-asc">Recorded — oldest first</option>
          <option value="upload-desc">Uploaded — newest first</option>
        </select>
      </div>
      <p id="video-count" class="text-sm text-neutral-500 mb-6"></p>

      <div id="video-grid" class="grid md:grid-cols-2 gap-8">
        {videos.map(v => (
          <div class="video-card"
            data-title={v.title.toLowerCase()}
            data-presenter={(v.presenter ?? '').toLowerCase()}
            data-description={(v.description ?? '').toLowerCase()}
            data-date={v.date ?? ''}
            data-upload={v.uploadDate ?? ''}
          >
            <button
              class="video-play group relative w-full aspect-video rounded-xl overflow-hidden bg-neutral-900 mb-3 flex items-center justify-center"
              data-src={embedSrc(v)}
              aria-label={`Play ${v.title}`}
            >
              <span class="w-16 h-16 rounded-full bg-white/90 group-hover:bg-white flex items-center justify-center transition-colors">
                <svg class="w-7 h-7 text-neutral-900 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
              </span>
            </button>
            <h2 class="text-lg font-bold text-neutral-900">{v.title}</h2>
            <p class="text-sm text-neutral-500">
              {v.presenter && <span class="font-medium">{v.presenter}</span>}
              {v.presenter && v.date && ' · '}
              {formatDate(v.date)}
            </p>
            {v.description && <p class="text-neutral-600 mt-1 text-sm line-clamp-3">{v.description}</p>}
          </div>
        ))}
      </div>
      <p id="video-none" class="hidden text-neutral-500 py-8 text-center">No videos match that search.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const grid = document.getElementById('video-grid')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.video-card'));
  const search = document.getElementById('video-search') as HTMLInputElement;
  const fieldSel = document.getElementById('video-field') as HTMLSelectElement;
  const sortSel = document.getElementById('video-sort') as HTMLSelectElement;
  const count = document.getElementById('video-count')!;
  const none = document.getElementById('video-none')!;

  // Click-to-load embeds: 600+ iframes up front would crush the page.
  grid.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.video-play');
    if (!btn) return;
    const iframe = document.createElement('iframe');
    iframe.src = btn.dataset.src + (btn.dataset.src!.includes('?') ? '&' : '?') + 'autoplay=1';
    iframe.allow = 'autoplay; fullscreen; picture-in-picture; encrypted-media';
    iframe.allowFullscreen = true;
    iframe.className = 'w-full aspect-video rounded-xl mb-3';
    btn.replaceWith(iframe);
  });

  function apply() {
    const q = search.value.trim().toLowerCase();
    const field = fieldSel.value;
    let visible = 0;
    for (const card of cards) {
      const hay = field
        ? card.dataset[field] ?? ''
        : `${card.dataset.title} ${card.dataset.presenter} ${card.dataset.description}`;
      const show = !q || hay.includes(q);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    count.textContent = q ? `${visible} of ${cards.length} videos` : `${cards.length} videos`;
    none.classList.toggle('hidden', visible > 0);
  }

  function resort() {
    const [key, dir] = sortSel.value.split('-');
    const attr = key === 'upload' ? 'upload' : 'date';
    const sorted = cards.slice().sort((a, b) => {
      const cmp = (a.dataset[attr] ?? '').localeCompare(b.dataset[attr] ?? '');
      return dir === 'asc' ? cmp : -cmp;
    });
    for (const card of sorted) grid.appendChild(card);
  }

  search.addEventListener('input', apply);
  fieldSel.addEventListener('change', apply);
  sortSel.addEventListener('change', resort);
  apply();
</script>
