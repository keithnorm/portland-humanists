---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getVideos } from '../../lib/membersStore';

const videos = (await getVideos()).slice().sort((a, b) => b.date.localeCompare(a.date));

function formatDate(iso: string): string {
  const d = new Date(`${iso}T12:00:00`);
  return isNaN(d.getTime()) ? iso : new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);
}
---

<BaseLayout title="Members-Only Videos - Humanists of Greater Portland">
  <section class="hgp-cta text-white py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/members" class="inline-flex items-center gap-2 text-[var(--hgp-on-primary)] hover:text-white mb-4 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Members Area
      </a>
      <h1 class="text-4xl font-bold mb-2">Members-Only Videos</h1>
      <p class="text-[var(--hgp-on-primary)]">Recordings not published on the public site. Please don't share these links.</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {videos.length === 0 ? (
        <p class="text-neutral-600">No members-only videos yet.</p>
      ) : (
        <div class="grid md:grid-cols-2 gap-8">
          {videos.map(v => (
            <div>
              <div class="aspect-video rounded-xl overflow-hidden bg-neutral-900 mb-3">
                <iframe
                  width="100%"
                  height="100%"
                  src={`https://www.youtube.com/embed/${v.youtubeId}`}
                  title={v.title}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              </div>
              <h2 class="text-lg font-bold text-neutral-900">{v.title}</h2>
              <p class="text-sm text-neutral-500">{formatDate(v.date)}</p>
              {v.description && <p class="text-neutral-600 mt-1 text-sm">{v.description}</p>}
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
