---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import { EventVisualEditor } from '../../components/EventVisualEditor';
import client from '../../../tina/__generated__/client';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(event => ({
    params: { slug: event.slug },
    props: { slug: event.slug },
  }));
}

const { slug } = Astro.props;
const tinaResult = await client.queries.events({ relativePath: `${slug}.md` });
const eventData = tinaResult.data.events;
const settingsResult = await client.queries.settings({ relativePath: 'general.json' });
const defaultZoomLink = settingsResult.data.settings.meetingInfo?.defaultZoomLink ?? '';
const timezone = settingsResult.data.settings.timezone ?? 'America/Los_Angeles';

---

<BaseLayout title={`${eventData.title} - Humanists of Greater Portland`}>
  <EventVisualEditor
    query={tinaResult.query}
    variables={tinaResult.variables}
    data={tinaResult.data}
    defaultZoomLink={defaultZoomLink}
    timezone={timezone}
    client:tina
  />
  <script>
    document.querySelectorAll('button.zoom-reveal-btn[data-zoom]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        window.open(this.dataset.zoom, '_blank', 'noopener,noreferrer');
      });
    });
  </script>
</BaseLayout>
