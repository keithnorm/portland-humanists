---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import { parseInTimezone } from '../../utils/time';
import siteSettings from '../../content/settings/general.json';

const allEvents = await getCollection('events');
const timezone = siteSettings.timezone ?? 'America/Los_Angeles';

const now = new Date();

const upcomingEvents = allEvents
  .filter(event => event.data.startTime && event.data.endTime && parseInTimezone(event.data.endTime, timezone) > now)
  .sort((a, b) => parseInTimezone(a.data.startTime, timezone).getTime() - parseInTimezone(b.data.startTime, timezone).getTime());

function formatTime(isoStr: string, tz: string): string {
  return new Intl.DateTimeFormat('en-US', {
    hour: 'numeric', minute: '2-digit', hour12: true, timeZone: tz,
  }).format(new Date(isoStr));
}

function timezoneAbbr(isoStr: string, tz: string): string {
  return new Intl.DateTimeFormat('en-US', { timeZone: tz, timeZoneName: 'short' })
    .formatToParts(new Date(isoStr))
    .find(p => p.type === 'timeZoneName')?.value ?? '';
}
---

<BaseLayout title="Events - Humanists of Greater Portland">
  <!-- Hero -->
  <section class="hgp-cta text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Sunday Programs</h1>
      <p class="text-xl text-[var(--hgp-on-primary)] max-w-2xl">
        Join us every Sunday for engaging presentations on science, reason, ethics, and humanist values.
        Attend in person at Friendly House or join us via Zoom.
      </p>
    </div>
  </section>

  <!-- Subnav -->
  <div class="bg-white border-b border-neutral-200 sticky top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-1 py-2">
        <a href="/events" class="px-4 py-2 rounded-lg text-sm font-medium bg-[var(--hgp-surface)] text-[var(--hgp-primary)]">Upcoming</a>
        <a href="/events/calendar" class="px-4 py-2 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-100 transition-colors">Calendar</a>
        <a href="/events/past" class="px-4 py-2 rounded-lg text-sm font-medium text-neutral-600 hover:bg-neutral-100 transition-colors">Past Programs</a>
      </nav>
    </div>
  </div>

  <!-- Upcoming Events -->
  <section class="py-16 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">Upcoming Programs</h2>

      {upcomingEvents.length === 0 ? (
        <div class="bg-white rounded-xl p-8 text-center">
          <p class="text-neutral-600">No upcoming events scheduled at this time. Check back soon!</p>
        </div>
      ) : (
        <div class="space-y-6">
          {upcomingEvents.map((event) => (
            <a
              href={`/events/${event.slug}`}
              class="block bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden"
            >
              <div class="md:flex">
                <div class="md:w-48 hgp-card-grad p-8 flex flex-col justify-center items-center text-white">
                  <div class="text-center">
                    <div class="text-3xl font-bold mb-1">
                      {new Intl.DateTimeFormat('en-US', { month: 'short' }).format(parseInTimezone(event.data.startTime, timezone)).toUpperCase()}
                    </div>
                    <div class="text-5xl font-bold mb-1">
                      {parseInTimezone(event.data.startTime, timezone).getDate()}
                    </div>
                    <div class="text-lg">
                      {new Intl.DateTimeFormat('en-US', { weekday: 'short' }).format(parseInTimezone(event.data.startTime, timezone))}
                    </div>
                  </div>
                </div>

                <div class="flex-1 p-6 md:p-8">
                  <h3 class="text-2xl font-bold text-neutral-900 mb-3">{event.data.title}</h3>

                  <div class="space-y-2 mb-4">
                    <div class="flex items-center gap-3 text-neutral-700">
                      <svg class="w-5 h-5 text-[var(--hgp-primary)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                      <span>{event.data.presenter} &mdash; {event.data.presenterTitle}</span>
                    </div>
                    <div class="flex items-center gap-3 text-neutral-700">
                      <svg class="w-5 h-5 text-[var(--hgp-primary)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span>{formatTime(event.data.startTime, timezone)} - {formatTime(event.data.endTime, timezone)} {timezoneAbbr(event.data.endTime, timezone)}</span>
                    </div>
                    <div class="flex items-center gap-3 text-neutral-700">
                      <svg class="w-5 h-5 text-[var(--hgp-primary)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      <span>{event.data.location}</span>
                    </div>
                  </div>

                  <p class="text-neutral-600 mb-4 line-clamp-2">{event.data.description}</p>

                  <span class="inline-flex items-center gap-2 text-[var(--hgp-primary)] font-medium">
                    View Details
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 hgp-cta text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Never Miss a Program</h2>
      <p class="text-xl text-[var(--hgp-on-primary)] mb-8">
        Join our mailing list to receive weekly reminders and updates about upcoming events.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/join" class="inline-block bg-white text-[var(--hgp-primary)] px-8 py-4 rounded-lg font-bold text-lg hover:bg-[var(--hgp-surface-alt)] transition-colors">
          Join Our Community
        </a>
        <a href="/events/calendar" class="inline-block border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white hover:text-[var(--hgp-primary)] transition-colors">
          View Calendar
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
