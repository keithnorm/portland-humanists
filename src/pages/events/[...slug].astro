---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { EventVisualEditor } from '../../components/EventVisualEditor';
import { getEntry } from 'astro:content';
import client from '../../../tina/__generated__/client';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

let tinaResult;
try {
  tinaResult = await client.queries.events({ relativePath: `${slug}.md` });
} catch {
  // Tina Cloud may not have indexed this event yet — fall back to content collections
  const entry = await getEntry('events', slug);
  if (!entry) return Astro.redirect('/404');
  tinaResult = {
    query: '',
    variables: { relativePath: `${slug}.md` },
    data: {
      events: {
        ...entry.data,
        date: entry.data.date instanceof Date ? entry.data.date.toISOString() : entry.data.date,
        startTime: entry.data.startTime instanceof Date ? entry.data.startTime.toISOString() : entry.data.startTime,
        endTime: entry.data.endTime instanceof Date ? entry.data.endTime.toISOString() : entry.data.endTime,
        body: null,
        _sys: { filename: slug, relativePath: `${slug}.md` },
      },
    },
  };
}

const eventData = tinaResult.data.events;

let timezone = 'America/Los_Angeles';
try {
  const settingsResult = await client.queries.settings({ relativePath: 'general.json' });
  timezone = settingsResult.data.settings.timezone ?? 'America/Los_Angeles';
} catch { /* use defaults */ }

---

<BaseLayout title={`${eventData.title} - Humanists of Greater Portland`}>
  <EventVisualEditor
    query={tinaResult.query}
    variables={tinaResult.variables}
    data={tinaResult.data}
    timezone={timezone}
    client:tina
  />
  <script>
    (function () {
      const section = document.getElementById('event-details-card');
      if (!section) return;

      const rawStart = (section as HTMLElement).dataset.start;
      const rawEnd = (section as HTMLElement).dataset.end;
      if (!rawStart || !rawEnd) return;

      const startMs = new Date(rawStart.replace(' ', 'T')).getTime();
      const endMs = new Date(rawEnd.replace(' ', 'T')).getTime();
      if (isNaN(startMs) || isNaN(endMs)) return;

      const now = Date.now();
      const THIRTY_MIN = 30 * 60 * 1000;

      function enableZoomBtn() {
        const btn = document.getElementById('event-zoom-btn') as HTMLAnchorElement | null;
        if (!btn) return;
        const href = btn.dataset.href;
        if (href) btn.setAttribute('href', href);
        btn.style.pointerEvents = '';
        btn.style.opacity = '';
        btn.removeAttribute('aria-disabled');
      }

      if (now >= startMs && now <= endMs) {
        const banner = document.getElementById('event-live-banner-live');
        if (banner) banner.style.display = 'flex';
        enableZoomBtn();
      } else if (now >= startMs - THIRTY_MIN && now < startMs) {
        const banner = document.getElementById('event-live-banner-soon');
        if (banner) {
          banner.style.display = 'flex';
          const minutesLeft = Math.round((startMs - now) / 60000);
          const textEl = document.getElementById('event-live-banner-soon-text');
          if (textEl) textEl.textContent = `Starting in ${minutesLeft} minute${minutesLeft !== 1 ? 's' : ''}`;
        }
        enableZoomBtn();
      }
    })();
  </script>
</BaseLayout>
