---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { HomeVisualEditor } from '../components/HomeVisualEditor';
import client from '../../tina/__generated__/client';

const allEvents = await getCollection('events');

function parseStartTime(startTime: string): Date {
  return new Date(startTime.replace(' ', 'T'));
}

const now = new Date();

const upcomingEvents = allEvents
  .filter(event => new Date(event.data.endTime.replace(' ', 'T')) > now)
  .sort((a, b) => parseStartTime(a.data.startTime).getTime() - parseStartTime(b.data.startTime).getTime());

const recentRecordings = allEvents
  .filter(event => new Date(event.data.endTime.replace(' ', 'T')) <= now && (event.data.youtubeId || event.data.vimeoId))
  .sort((a, b) => parseStartTime(b.data.startTime).getTime() - parseStartTime(a.data.startTime).getTime())
  .slice(0, 3);

const tinaResult = await client.queries.homepage({ relativePath: 'home.json' });
const settingsResult = await client.queries.settings({ relativePath: 'general.json' });
const defaultZoomLink = settingsResult.data.settings.meetingInfo?.defaultZoomLink ?? '';
---

<BaseLayout>
  <HomeVisualEditor
    query={tinaResult.query}
    variables={tinaResult.variables}
    data={tinaResult.data}
    upcomingEvents={upcomingEvents}
    recentRecordings={recentRecordings}
    defaultZoomLink={defaultZoomLink}
    client:tina
  />
</BaseLayout>

<script>
  (function () {
    const card = document.getElementById('featured-event-card');
    if (!card) return;

    const rawStart = (card as HTMLElement).dataset.start;
    const rawEnd = (card as HTMLElement).dataset.end;
    if (!rawStart || !rawEnd) return;

    const startMs = new Date(rawStart.replace(' ', 'T')).getTime();
    const endMs = new Date(rawEnd.replace(' ', 'T')).getTime();
    if (isNaN(startMs) || isNaN(endMs)) return;

    const now = Date.now();
    const THIRTY_MIN = 30 * 60 * 1000;

    function enableZoomBtn() {
      const btn = document.getElementById('featured-zoom-btn') as HTMLAnchorElement | null;
      if (!btn) return;
      const href = btn.dataset.href;
      if (href) btn.setAttribute('href', href);
      btn.style.pointerEvents = '';
      btn.style.opacity = '';
      btn.removeAttribute('aria-disabled');
    }

    if (now >= startMs && now <= endMs) {
      const banner = document.getElementById('live-banner-live');
      if (banner) banner.style.display = 'flex';
      enableZoomBtn();
    } else if (now >= startMs - THIRTY_MIN && now < startMs) {
      const banner = document.getElementById('live-banner-soon');
      if (banner) {
        banner.style.display = 'flex';
        const minutesLeft = Math.round((startMs - now) / 60000);
        const textEl = document.getElementById('live-banner-soon-text');
        if (textEl) textEl.textContent = `Starting in ${minutesLeft} minute${minutesLeft !== 1 ? 's' : ''}`;
      }
      enableZoomBtn();
    }
  })();
</script>
