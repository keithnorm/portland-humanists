---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { PageVisualEditor } from '../components/PageVisualEditor';
import client from '../../tina/__generated__/client';
import '../styles/global.css';

export async function getStaticPaths() {
  // Use Astro content collection for path discovery only — fast and offline-friendly
  const pages = await getCollection('pages');
  return pages.map(page => ({
    params: { slug: page.slug },
    props: { slug: page.slug },
  }));
}

const { slug } = Astro.props;

// Fetch via Tina's GraphQL client so the query + variables are available
// for useTina's postMessage listener in the browser (enables visual editing)
const tinaResult = await client.queries.pages({ relativePath: `${slug}.md` });
const pageData = tinaResult.data.pages;
---

<BaseLayout title={`${pageData.title} - Humanists of Greater Portland`}>
  <PageVisualEditor
    query={tinaResult.query}
    variables={tinaResult.variables}
    data={tinaResult.data}
    client:load
  />
</BaseLayout>

