---
import { getCollection } from 'astro:content';

// Get all pages that should show in navigation
const allPages = await getCollection('pages');
const navPages = allPages
  .filter(page => page.data.showInNav !== false)
  .sort((a, b) => (a.data.navOrder || 999) - (b.data.navOrder || 999));

// Build navigation structure with parent/child relationships
const topLevelPages = navPages.filter(page => !page.data.parent);
const pagesByParent = navPages.reduce((acc, page) => {
  if (page.data.parent) {
    if (!acc[page.data.parent]) acc[page.data.parent] = [];
    acc[page.data.parent].push(page);
  }
  return acc;
}, {} as Record<string, typeof navPages>);

interface NavItem {
  label: string;
  href: string;
  order: number;
  highlight?: boolean;
  donateHighlight?: boolean;
  external?: boolean;
  children?: { label: string; href: string }[];
}

// Static navigation items (hardcoded pages)
const staticNavItems: NavItem[] = [
  { label: 'Events', href: '/events', order: 3, children: [
    { label: 'Upcoming', href: '/events' },
    { label: 'Calendar', href: '/events/calendar' },
    { label: 'Past Programs', href: '/events/past' },
  ]},
  { label: 'Members', href: '/members', order: 8 },
  { label: 'Donate', href: '/contribute', order: 9, donateHighlight: true },
  { label: 'Join Us', href: '/join', order: 10, highlight: true },
];

// Combine static and dynamic pages, sorting by order
const allNavItems: NavItem[] = [
  ...staticNavItems,
  ...topLevelPages.map(page => ({
    label: page.data.title,
    href: `/${page.slug}`,
    order: page.data.navOrder || 999,
    children: pagesByParent[page.slug]?.map(child => ({
      label: child.data.title,
      href: `/${child.slug}`,
    })),
  })),
].sort((a, b) => a.order - b.order);

const currentPath = Astro.url.pathname;
---

<nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="flex justify-between items-center h-20">
    <div class="flex items-center">
      <a href="/" class="hover:opacity-80 transition-opacity">
        <img src="/logo.png" alt="Humanists of Greater Portland" class="h-20 w-auto" />
      </a>
    </div>

    <div class="hidden md:flex items-center gap-8">
      {allNavItems.map(item => (
        item.highlight ? (
          <a
            href={item.href}
            class="bg-[var(--hgp-primary)] text-white px-4 py-2 rounded-lg hover:bg-[var(--hgp-mid)] transition-colors font-medium"
          >
            {item.label}
          </a>
        ) : item.donateHighlight ? (
          <a
            href={item.href}
            class="border-2 border-[var(--hgp-primary)] text-[var(--hgp-primary)] px-4 py-2 rounded-lg hover:bg-[var(--hgp-primary)] hover:text-white transition-colors font-medium"
          >
            {item.label}
          </a>
        ) : item.children && item.children.length > 0 ? (
          <div class="relative group">
            <a
              href={item.href}
              class={`text-neutral-700 hover:text-[var(--hgp-primary)] transition-colors font-medium ${currentPath === item.href ? 'text-[var(--hgp-primary)]' : ''}`}
            >
              {item.label}
              <svg class="w-4 h-4 inline ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <!-- Dropdown menu -->
            <div class="absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-100">
              <div class="py-1">
                {item.children.map(child => (
                  <a
                    href={child.href}
                    class={`block px-4 py-2 text-sm text-neutral-700 hover:bg-[var(--hgp-surface)] hover:text-[var(--hgp-primary)] ${currentPath === child.href ? 'bg-[var(--hgp-surface)] text-[var(--hgp-primary)]' : ''}`}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class={`text-neutral-700 hover:text-[var(--hgp-primary)] transition-colors font-medium ${currentPath === item.href ? 'text-[var(--hgp-primary)]' : ''}`}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            {item.label}
          </a>
        )
      ))}
    </div>

    <button id="mobile-menu-button" class="md:hidden p-2 text-neutral-700 hover:text-[var(--hgp-primary)]" aria-label="Toggle menu">
      <svg id="menu-open-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden absolute top-full left-0 right-0 bg-white shadow-lg z-50 overflow-y-auto max-h-[calc(100vh-5rem)]">
    <div class="px-2 pt-2 pb-3 space-y-1">
      {allNavItems.map(item => (
        item.highlight ? (
          <a
            href={item.href}
            class="block bg-[var(--hgp-primary)] text-white px-3 py-2 rounded-lg font-medium text-center"
          >
            {item.label}
          </a>
        ) : item.donateHighlight ? (
          <a
            href={item.href}
            class="block border-2 border-[var(--hgp-primary)] text-[var(--hgp-primary)] px-3 py-2 rounded-lg font-medium text-center"
          >
            {item.label}
          </a>
        ) : item.children && item.children.length > 0 ? (
          <div>
            <a
              href={item.href}
              class={`block px-3 py-2 rounded-md text-base font-medium ${currentPath === item.href ? 'text-[var(--hgp-primary)] bg-[var(--hgp-surface)]' : 'text-neutral-700 hover:text-[var(--hgp-primary)] hover:bg-gray-50'}`}
            >
              {item.label}
            </a>
            <div class="pl-4 space-y-1">
              {item.children.map(child => (
                <a
                  href={child.href}
                  class={`block px-3 py-2 rounded-md text-sm ${currentPath === child.href ? 'text-[var(--hgp-primary)] bg-[var(--hgp-surface)]' : 'text-neutral-600 hover:text-[var(--hgp-primary)] hover:bg-gray-50'}`}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class={`block px-3 py-2 rounded-md text-base font-medium ${currentPath === item.href ? 'text-[var(--hgp-primary)] bg-[var(--hgp-surface)]' : 'text-neutral-700 hover:text-[var(--hgp-primary)] hover:bg-gray-50'}`}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            {item.label}
          </a>
        )
      ))}
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpenIcon = document.getElementById('menu-open-icon');
  const menuCloseIcon = document.getElementById('menu-close-icon');

  mobileMenuButton?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');

    if (isHidden) {
      mobileMenu?.classList.remove('hidden');
      menuOpenIcon?.classList.add('hidden');
      menuCloseIcon?.classList.remove('hidden');
    } else {
      mobileMenu?.classList.add('hidden');
      menuOpenIcon?.classList.remove('hidden');
      menuCloseIcon?.classList.add('hidden');
    }
  });
</script>
